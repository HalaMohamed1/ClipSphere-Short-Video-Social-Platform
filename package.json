{
  "name": "clipsphere-backend",
  "version": "1.0.0",
  "description": "ClipSphere - Short Video Social Platform Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:all": "concurrently -k -n api,web -c blue,magenta \"npm run dev\" \"wait-on tcp:127.0.0.1:5000 && npm run dev --prefix nextjs-frontend\"",
