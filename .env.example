# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/clipsphere

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h

# Server Base URL
SERVER_URL=http://localhost:5000

# MinIO / S3-compatible storage (match docker-compose MinIO credentials and bucket names)
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_URL=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_VIDEOS=clipsphere-videos
S3_BUCKET_THUMBNAILS=clipsphere-thumbnails

# Upload limits (bytes). Multer enforces these on multipart routes.
UPLOAD_MAX_BYTES=52428800
UPLOAD_THUMBNAIL_MAX_BYTES=5242880

# Presigned PUT URL expiry (seconds)
S3_PRESIGN_EXPIRES_SECONDS=300
