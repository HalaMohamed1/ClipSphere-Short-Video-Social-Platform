# Server Configuration
# Default 5050: macOS often reserves port 5000 for AirPlay Receiver (see System Settings → AirDrop & Handoff).
PORT=5050
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/clipsphere

# Redis Configuration (Phase 4: BullMQ queues and caching)
# Local: redis://localhost:6379
# Docker: redis://cache:6379 (see docker-compose.yml)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=24h

# Public base URL of this API (used for /api/v1/videos/:id/stream|thumbnail in JSON). No /api/v1 suffix.
SERVER_URL=http://localhost:5050

# Browser clients (CORS + cookie SameSite context). Comma-separated for multiple dev URLs.
CLIENT_ORIGIN=http://localhost:3000

# MinIO / S3-compatible storage (see docker-compose minio service)
# Requires Docker Desktop (or another engine) RUNNING so /var/run/docker.sock exists.
# Start locally: docker compose up -d minio minio-init   (or: docker-compose up -d minio minio-init)
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_VIDEOS=clipsphere-videos
MINIO_BUCKET_THUMBNAILS=clipsphere-thumbnails
# Max upload size for Multer (MB)
MAX_VIDEO_UPLOAD_MB=200

# FFmpeg — required for video upld (duration + thumbnails). Install: macOS `brew install ffmpeg`, Windows https://ffmpeg.org
# If ffprobe/ffmpeg are not found, set paths (Apple Silicon Homebrew uses /opt/homebrew/bin/, Intel uses /usr/local/bin/):
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# Stripe (test mode: https://dashboard.stripe.com/test/apikeys )
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
# Next.js (copy to nextjs-frontend/.env.local as well)
# NEXT_PUBLIC_API_URL=http://localhost:5050/api/v1

# Optional: public site URL for email template links
# CLIENT_URL=http://localhost:3000

# Email (optional; falls back to Ethereal in dev)
# EMAIL_SERVICE=
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=noreply@clipsphere.local
