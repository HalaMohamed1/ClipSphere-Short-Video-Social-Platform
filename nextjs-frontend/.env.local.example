# Copy to .env.local (do not commit .env.local).
#
# Leave NEXT_PUBLIC_API_URL unset so the app uses same-origin `/api/...` URLs (recommended).
#
# Where Next.js proxies `/api/*` (server-side only — not exposed to the browser):
# NEXT_INTERNAL_API_URL=http://127.0.0.1:5000
#
# Optional: direct browser → API (needs CORS on Express):
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
